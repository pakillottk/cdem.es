---
import Layout from '../layouts/Layout.astro';
---
<Layout>
	<div class="home-page">
		<!-- Hero -->
		<section class="home-hero">
			<div
				class="home-hero__bg"
				style="background-image: url('/home foto.png');"
				aria-hidden="true"
			></div>
			<!-- <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black"></div> -->

			<div class="home-hero__content">
				<h1 class="home-hero__title">
					CREACIÓN Y DISEÑO<br />
					DE EVENTOS MUSICALES
				</h1>
				<p class="home-hero__subtitle">
					La creatividad que mueve la música
				</p>

				<div class="home-hero__actions">
					<a
						href="#contacto"
						class="home-hero__cta home-hero__cta--primary"
					>
						Contrata tu evento
					</a>
					<a
						href="#producciones"
						class="home-hero__cta home-hero__cta--secondary"
					>
						Descubre nuestros proyectos
					</a>
				</div>
			</div>
		</section>

		<!-- Claim -->
		<section
			id="servicio"
			class="home-claim"
		>
			<div class="home-claim__inner">
				<p class="home-claim__text">
					"Creación, diseño y producción de experiencias musicales. Trabajamos con artistas, instituciones y
					festivales para llevar la música en vivo a otro nivel."
				</p>
			</div>
		</section>

		<!-- Servicios -->
		<section
			id="eventos"
			class="home-services"
		>
			<div class="home-services__grid">
				<div class="home-service-card">
					<div class="home-service-card__icon-wrap">
						<span class="home-service-card__icon-anim"><img src="/iconos/organizacion-integral.png"></span>
					</div>
					<h3 class="home-service-card__title">
						Organización integral de<br />festivales, conciertos y ciclos musicales
					</h3>
				</div>
				<div class="home-service-card">
					<div class="home-service-card__icon-wrap">
						<span class="home-service-card__icon-anim"><img src="/iconos/gestion-artistas.png"></span>
					</div>
					<h3 class="home-service-card__title">
						Gestión directa con artistas<br />y oficinas de booking
					</h3>
				</div>
				<div class="home-service-card">
					<div class="home-service-card__icon-wrap">
						<span class="home-service-card__icon-anim"><img src="/iconos/coordinacion-tecnica.png"></span>
					</div>
					<h3 class="home-service-card__title">
						Coordinación técnica,<br />logística y producción escénica
					</h3>
				</div>
				<div class="home-service-card">
					<div class="home-service-card__icon-wrap">
						<span class="home-service-card__icon-anim"><img src="/iconos/curaduria-y-asesoramiento.png"></span>
					</div>
					<h3 class="home-service-card__title">
						Curaduría y asesoramiento<br />artístico
					</h3>
				</div>
				
			</div>
		</section>

	</div>
</Layout>
