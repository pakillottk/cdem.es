---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="producciones-page">
    <!-- Hero producciones -->

    <section class="producciones-hero">
      <div class="producciones-hero__banner">
        <div class="producciones-hero__overlay">
          <p class="producciones-hero__quote">
            Cada producción es una experiencia diseñada para vivirse.
          </p>
        </div>
      </div>
    </section>

    <!-- Grid de producciones destacadas -->
    <section class="producciones-grid">
      <div class="producciones-grid__inner">
        <div class="producciones-grid__list">
          <!-- Vive Linares -->
          <article class="producciones-grid__item">
            <div class="producciones-grid__image">
              <img
                src="/portada vive Linares2.jpg"
                alt="Vive Linares Fest"
                class="max-w-full max-h-full object-contain"
              />
            </div>
          </article>

          <!-- Festival de Jazz -->
          <article class="producciones-grid__item">
          <div class="producciones-grid__image">
              <img
                src="/portada festival jazz.jpg"
                alt="Festival de Jazz"
                class="max-w-full max-h-full object-contain"
              />
            </div>
          </article>

          <!-- New Wave -->
          <article class="producciones-grid__item">
            <div class="producciones-grid__image">
              <img
                src="/portada New Wave2.jpg"
                alt="New Wave"
                class="max-w-full max-h-full object-contain"
              />
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Texto conceptual a todo lo ancho -->
    <section class="producciones-text-intro">
      <div class="producciones-text-intro__inner">
        <p class="producciones-text-intro__title">
          Cada producción refleja nuestra forma de entender la música en vivo:
        </p>
        <p
          class="producciones-text-intro__highlight"
        >
          diseño, rigor y emoción.
        </p>
      </div>
    </section>

    <!-- Texto descriptivo + CTA en fila -->
    <section class="producciones-cta-section">
      <div class="producciones-cta-section__inner">
        <div>
				<p class="producciones-cta-section__text">
            Desde la idea inicial hasta el último acorde, diseñamos experiencias
            que conectan con artistas y público, cuidando la identidad visual,
            el relato y cada detalle técnico y artístico.
          </p>
          <p
            class="producciones-cta-section__headline"
          >
            ¿Hablamos de tu próximo proyecto?
          </p>
        </div>
        <a
          href="/contacto"
          class="producciones-cta-section__button"
        >
          Contactar
        </a>
      </div>
    </section>
  </div>
</Layout>
