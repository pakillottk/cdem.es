---
import Layout from '../layouts/Layout.astro';
---
<Layout>
	<script src="../scripts/servicio-scroll.js"></script>
	<div class="min-h-screen bg-black text-white font-sans overflow-x-hidden">
		<!-- Intro servicios -->
		<section
			class="bg-black py-10 px-6 lg:px-0 border-y border-white/5 flex items-center justify-center"
		>
			<div class="max-w-5xl text-center space-y-4 w-full">
				<img
					src="/home foto.png"
					alt="CDEM Producciones"
					class="w-full h-[100px] object-cover object-top mx-auto"
				/>
				<p class="text-base font-secondary uppercase sm:text-lg md:text-xl leading-relaxed font-medium">
					CDEM Producciones diseña, produce y gestiona eventos musicales con una mirada integral, dándoles una
					identidad propia. Trabajamos con artistas, instituciones y festivales para crear experiencias sólidas,
					cuidadas y memorables, donde la música en vivo es la protagonista. Desde la idea inicial hasta el
					directo, cuidamos cada detalle para que la música suene como debe.
				</p>
			</div>
		</section>

		<!-- Bloque de servicios principales (secciones inclinadas tipo cremallera) -->
		<section class="bg-black py-14 px-6 lg:px-0">
			<div class="services-zipper space-y-2 md:space-y-3">
				<!-- Fila 1: Organización integral (azul) + Coordinación técnica (blanca) -->
				<div class="services-zipper__row">
					<article class="services-flow-card services-flow-card--slant-left bg-cyan-500 text-black">
						<div class="flex w-full gap-4 items-center justify-start">
							<img
								class="w-24 h-24 sm:w-28 sm:h-28 flex-shrink-0 object-cover"
								src="/iconos/SERVICIOSorganizacionintegral.png"
								alt="Organización integral de festivales, conciertos y ciclos musicales"
							/>
							<h2 class="text-base font-secondary sm:text-lg font-extrabold tracking-[0.2em] uppercase flex-1 text-left">
								Organización integral de festivales, conciertos y ciclos musicales
							</h2>
						</div>
						<p class="mt-3 font-primary text-sm sm:text-base leading-relaxed font-medium w-full">
							Organización de festivales, conciertos y ciclos musicales desde la planificación hasta la
							ejecución final.
						</p>
					</article>
					<article class="services-flow-card services-flow-card--slant-right bg-white text-black">
						<div class="flex w-full gap-4 items-center justify-end">
							<h2 class="text-base font-secondary sm:text-lg font-extrabold tracking-[0.2em] uppercase flex-1 text-right">
								Coordinación técnica, logística y producción escénica
							</h2>
							<img
								class="w-24 h-24 sm:w-28 sm:h-28 flex-shrink-0 object-cover"
								src="/iconos/coordinacion-tecnica.png"
								alt="Coordinación técnica, logística y producción escénica"
							/>
						</div>
						<p class="mt-3 font-primary text-sm sm:text-base leading-relaxed font-medium w-full">
							Relación directa con artistas y agencias nacionales e internacionales. Coordinamos
							negociaciones, contratos y logística.
						</p>
					</article>
				</div>

				<!-- Fila 2: Gestión directa (azul) + Curaduría (blanca) -->
				<div class="services-zipper__row">
					<article class="services-flow-card services-flow-card--slant-left bg-cyan-500 text-black">
						<div class="flex w-full gap-4 items-center justify-start">
							<img
								class="w-24 h-24 sm:w-28 sm:h-28 flex-shrink-0 object-cover"
								src="/iconos/SERVICIOSgestionartistas.png"
								alt="Gestión directa con artistas y oficinas de booking"
							/>
							<h2 class="text-base font-secondary sm:text-lg font-extrabold tracking-[0.2em] uppercase flex-1 text-left">
								Gestión directa con artistas y oficinas de booking
							</h2>
						</div>
						<p class="mt-3 font-primary text-sm sm:text-base leading-relaxed font-medium w-full">
							Planificación técnica completa: riders, montajes, necesidades escénicas, sonido, iluminación y
							coordinación de equipos.
						</p>
					</article>
					<article class="services-flow-card services-flow-card--slant-right bg-white text-black">
						<div class="flex w-full gap-4 items-center justify-end">
							<h2 class="text-base font-secondary sm:text-lg font-extrabold tracking-[0.2em] uppercase flex-1 text-right">
								Curaduría y asesoramiento artístico
							</h2>
							<img
								class="w-24 h-24 sm:w-28 sm:h-28 flex-shrink-0 object-cover"
								src="/iconos/curaduria-y-asesoramiento.png"
								alt="Curaduría y asesoramiento artístico"
							/>
						</div>
						<p class="mt-3 font-primary text-sm sm:text-base leading-relaxed font-medium w-full">
							Conceptualizamos y diseñamos la programación de tu evento con coherencia artística, identidad
							propia y calidad musical.
						</p>
					</article>
				</div>

				<!-- Fila 3: Producción ejecutiva (azul) + Diseño conceptual (blanca) -->
				<div class="services-zipper__row">
					<article class="services-flow-card services-flow-card--slant-left bg-cyan-500 text-black">
						<div class="flex w-full gap-4 items-center justify-start">
							<img
								class="w-24 h-24 sm:w-28 sm:h-28 flex-shrink-0 object-cover"
								src="/iconos/SERVICIOS produccion blanco.png"
								alt="Producción ejecutiva y coordinación general"
							/>
							<h2 class="text-base font-secondary sm:text-lg font-extrabold tracking-[0.2em] uppercase flex-1 text-left">
								Producción ejecutiva y coordinación general
							</h2>
						</div>
						<p class="mt-3 font-primary text-sm sm:text-base leading-relaxed font-medium w-full">
							Supervisión global del proyecto, presupuestos, equipos y tiempos.
						</p>
					</article>
					<article class="services-flow-card services-flow-card--slant-right bg-white text-black">
						<div class="flex w-full gap-4 items-center justify-end">
							<h2 class="text-base font-secondary sm:text-lg font-extrabold tracking-[0.2em] uppercase flex-1 text-right">
								Diseño conceptual y dirección creativa
							</h2>
							<img
								class="w-24 h-24 sm:w-28 sm:h-28 flex-shrink-0 object-cover"
								src="/iconos/SERVICIOSdiseno.png"
								alt="Diseño conceptual y dirección creativa"
							/>
						</div>
						<p class="mt-3 font-primary text-sm sm:text-base leading-relaxed font-medium w-full">
							Desarrollo del concepto creativo y narrativo del evento. Definimos identidad, formato y
							experiencia para que cada proyecto tenga un carácter único.
						</p>
					</article>
				</div>
			</div>

			<!-- CTAs -->
			<div class="mt-10 flex flex-col sm:flex-row gap-10 justify-center items-center text-center">
				<a href="/contacto" class="contacto-draw-btn">
					<span class="contacto-draw-btn__text">Contrata tu evento</span>
					<svg class="contacto-draw-btn__svg" viewBox="0 0 240 60" preserveAspectRatio="none">
						<ellipse cx="120" cy="30" rx="112" ry="29" />
					</svg>
				</a>
				<a href="/producciones" class="contacto-draw-btn">
					<span class="contacto-draw-btn__text">Descubre nuestros proyectos</span>
					<svg class="contacto-draw-btn__svg" viewBox="0 0 240 60" preserveAspectRatio="none">
						<ellipse cx="120" cy="30" rx="112" ry="29" />
					</svg>
				</a>
			</div>
		</section>

	</div>
</Layout>
