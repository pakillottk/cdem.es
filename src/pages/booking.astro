---
import Layout from "../layouts/Layout.astro";
import ContactoSection from "../components/ContactoSection.astro";
import BookingGridSwiper from "../components/BookingGridSwiper";
import type { BookingSlide } from "../components/BookingGridSwiper";

const bookingSlides: BookingSlide[] = [
  {
    kind: "image",
    src: "/booking/img/Rosario Mohedano.jpg",
    alt: "Rosario Mohedano",
  },
  {
    kind: "pdf",
    href: "/booking/docs/Play%20star%202026%20CDEM.pdf",
    src: "/booking/img/PlayStar.jpg",
    alt: "Play Star",
  },
  {
    kind: "pdf",
    href: "/booking/docs/DOSSIER%20MECANO%202026.pdf",
    src: "/booking/img/Mecano deluxe.png",
    alt: "Mecano deluxe",
  },
];
---

<Layout>
  <div class="booking-page">
    <!-- Hero booking -->

    <section class="booking-hero">
      <div class="booking-hero__banner">
        <div class="booking-hero__overlay">
          <p class="booking-hero__quote">
            Gestion y contratacion de talento paa experiencias musicales en vivo
          </p>
        </div>
      </div>
    </section>

    <!-- Grid / Swiper según viewport -->
    <section class="booking-grid">
      <div class="booking-grid__inner">
        <BookingGridSwiper slides={bookingSlides} client:load />
      </div>
    </section>

    <!-- Texto conceptual a todo lo ancho -->
    <section class="booking-text-intro">
      <div class="booking-text-intro__inner">
        <p class="booking-text-intro__title">
          Donde el <span class="booking-text-intro__highlight">talento </span> encuentra su espacio en <span class="booking-text-intro__highlight">directo.</span>
        </p>
      </div>
    </section>

    <!-- Texto descriptivo + CTA en fila -->
    <ContactoSection />
  </div>
</Layout>
