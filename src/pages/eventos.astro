---
import Layout from '../layouts/Layout.astro';
---
<Layout>
	<script src="../scripts/eventos-scroll.js"></script>
	<div class="min-h-screen bg-black text-white font-primary">
		<!-- Hero eventos -->
		<section class="eventos-hero">
			<div class="eventos-hero__banner">
				<img src="/home foto.png" alt="CDEM Producciones" />
				<div class="eventos-hero__overlay">
					<p class="eventos-hero__quote">
						La música como experiencia, el directo como lenguaje
					</p>
				</div>
			</div>
		</section>

		<!-- Categorías de eventos -->
		<section class="eventos-categorias">
			<h2 class="eventos-categorias__title">Festivales</h2>
			<div id="eventos-festivales-list" class="eventos-festivales-list">
				<!-- Vive Linares Fest -->
				<article class="eventos-festival-card">
					<a href="https://vivelinares.com/" target="_blank" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/festivales/vive-linares.png" alt="Vive Linares Fest" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Vive Linares Fest</h2>
						</div>
					</a>
				</article>

				<!-- Ibero Joven -->
				<article class="eventos-festival-card">
					<a href="https://www.instagram.com/festivaliberojoven/" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/festivales/ibero-joven.png" alt="Ibero Joven" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Ibero Joven</h2>
						</div>
					</a>
				</article>

				<!-- Sarao Late -->
				<article class="eventos-festival-card">
					<a href="https://www.instagram.com/saraolateoficial/" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/festivales/sarao.png" alt="Sarao Late" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Sarao Late</h2>
						</div>
					</a>
				</article>
			</div>
		</section>

		<section class="eventos-categorias">
			<h2 class="eventos-categorias__title">Conciertos</h2>
			<div id="eventos-conciertos-list" class="eventos-festivales-list">
				<!-- La plazuela -->
				<article class="eventos-festival-card">
					<a href="https://www.enterticket.es/eventos/la-plazuela-ubeda-531737" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/conciertos/la plazuela.png" alt="La Plazuela" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">La plazuela</h2>
						</div>
					</a>
				</article>

				<!-- Diana Navarro -->
				<article class="eventos-festival-card">
					<a href="https://www.enterticket.es/eventos/diana-navarro-417399" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/conciertos/diana navarro.png" alt="Diana Navarro" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Diana Navarro</h2>
						</div>
					</a>
				</article>
			</div>
		</section>

	</div>
</Layout>
