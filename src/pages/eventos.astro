---
import Layout from '../layouts/Layout.astro';
import EventosCard from '../components/EventosCard.astro';
import { getCollection } from 'astro:content';
import { sortEventos, resolveEventoImageUrl } from '../lib/eventos';
import { HERO_IMG_SRC, HERO_IMG_SRCSET, HERO_IMG_SIZES } from '../data/hero-image';

const allEventos = await getCollection('eventos');
const published = allEventos.filter((evento) => evento.data.published !== false);

const festivales = sortEventos(
  published.filter((evento) => evento.data.category === 'festivales'),
);
const conciertos = sortEventos(
  published.filter((evento) => evento.data.category === 'conciertos'),
);
---
<Layout
  title="Eventos - CDEM"
  description="Festivales y conciertos producidos por CDEM: Vive Linares Fest, Ibero Joven, Sarao Late, La Plazuela, Diana Navarro y más."
>
  <script src="../scripts/eventos-scroll.js"></script>
  <div class="min-h-screen bg-black text-white font-primary">
    <section class="eventos-hero">
      <div class="eventos-hero__banner">
        <img
          src={HERO_IMG_SRC}
          srcset={HERO_IMG_SRCSET}
          sizes={HERO_IMG_SIZES}
          alt="CDEM Producciones"
          width="1920"
          height="1080"
          fetchpriority="high"
          decoding="async"
        />
        <div class="eventos-hero__overlay">
          <p class="eventos-hero__quote">
            La música como experiencia, el directo como lenguaje
          </p>
        </div>
      </div>
    </section>

    <section class="eventos-categorias">
      <h2 class="eventos-categorias__title">Festivales</h2>
      <div id="eventos-festivales-list" class="eventos-festivales-list">
        {festivales.map((evento) => (
          <EventosCard
            title={evento.data.title}
            href={evento.data.externalUrl}
            image={resolveEventoImageUrl(evento.data.image, evento.id)}
            imageAlt={evento.data.imageAlt}
            openInNewTab={evento.data.openInNewTab}
          />
        ))}
      </div>
    </section>

    <section class="eventos-categorias">
      <h2 class="eventos-categorias__title">Conciertos</h2>
      <div id="eventos-conciertos-list" class="eventos-festivales-list">
        {conciertos.map((evento) => (
          <EventosCard
            title={evento.data.title}
            href={evento.data.externalUrl}
            image={resolveEventoImageUrl(evento.data.image, evento.id)}
            imageAlt={evento.data.imageAlt}
            openInNewTab={evento.data.openInNewTab}
          />
        ))}
      </div>
    </section>
  </div>
</Layout>
