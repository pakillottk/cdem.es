---
import Layout from '../layouts/Layout.astro';
import { HERO_IMG_SRC, HERO_IMG_SRCSET, HERO_IMG_SIZES } from '../data/hero-image';
---
<Layout
  title="Eventos - CDEM"
  description="Festivales y conciertos producidos por CDEM: Vive Linares Fest, Ibero Joven, Sarao Late, La Plazuela, Diana Navarro y más."
>
	<script src="../scripts/eventos-scroll.js"></script>
	<div class="min-h-screen bg-black text-white font-primary">
		<!-- Hero eventos -->
		<section class="eventos-hero">
			<div class="eventos-hero__banner">
				<img
					src={HERO_IMG_SRC}
					srcset={HERO_IMG_SRCSET}
					sizes={HERO_IMG_SIZES}
					alt="CDEM Producciones"
					width="1920"
					height="1080"
					fetchpriority="high"
					decoding="async"
				/>
				<div class="eventos-hero__overlay">
					<p class="eventos-hero__quote">
						La música como experiencia, el directo como lenguaje
					</p>
				</div>
			</div>
		</section>

		<!-- Categorías de eventos -->
		<section class="eventos-categorias">
			<h2 class="eventos-categorias__title">Festivales</h2>
			<div id="eventos-festivales-list" class="eventos-festivales-list">
				<!-- Vive Linares Fest -->
				<article class="eventos-festival-card">
					<a href="https://vivelinares.com/" target="_blank" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/festivales/vive-linares.webp" alt="Vive Linares Fest" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Vive Linares Fest</h2>
						</div>
					</a>
				</article>

				<!-- Ibero Joven -->
				<article class="eventos-festival-card">
					<a href="https://www.instagram.com/festivaliberojoven/" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/festivales/ibero-joven.webp" alt="Ibero Joven" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Ibero Joven</h2>
						</div>
					</a>
				</article>

				<!-- Sarao Late -->
				<article class="eventos-festival-card">
					<a href="https://www.instagram.com/saraolateoficial/" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/festivales/sarao.webp" alt="Sarao Late" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Sarao Late</h2>
						</div>
					</a>
				</article>
			</div>
		</section>

		<section class="eventos-categorias">
			<h2 class="eventos-categorias__title">Conciertos</h2>
			<div id="eventos-conciertos-list" class="eventos-festivales-list">
				<!-- Diana Navarro (30 abril) -->
				<article class="eventos-festival-card">
					<a href="https://www.enterticket.es/eventos/diana-navarro-417399" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/conciertos/20260430diana navarro.webp" alt="Diana Navarro" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Diana Navarro</h2>
						</div>
					</a>
				</article>

				<!-- La Plazuela (11 julio) -->
				<article class="eventos-festival-card">
					<a href="https://www.enterticket.es/eventos/la-plazuela-ubeda-531737" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/conciertos/20260711la plazuela.webp" alt="La Plazuela" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">La Plazuela</h2>
						</div>
					</a>
				</article>

				<!-- Haze (8 agosto) -->
				<article class="eventos-festival-card">
					<a href="https://www.enterticket.es/eventos/haze-375235" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/conciertos/20260808haze.webp" alt="Haze" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Haze</h2>
						</div>
					</a>
				</article>

				<!-- Diana Navarro (22 agosto) -->
				<article class="eventos-festival-card">
					<a href="https://www.enterticket.es/eventos/diana-navarro-peal-de-becerro-216847" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/conciertos/20260822diana navarro.webp" alt="Diana Navarro 22 de agosto" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Diana Navarro</h2>
						</div>
					</a>
				</article>

				<!-- Feria New Wave (27 agosto) -->
				<article class="eventos-festival-card">
					<a href="https://www.enterticket.es/eventos/new-wave-seguridad-social-mago-de-oz-650191" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/conciertos/20260827Feria new wave.webp" alt="Feria New Wave" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">New Wave</h2>
						</div>
					</a>
				</article>

				<!-- Feria Pastora Soler (28 agosto) -->
				<article class="eventos-festival-card">
					<a href="https://www.enterticket.es/eventos/pastora-soler-linares-956945" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/conciertos/20260828Feria pastora soler.webp" alt="Pastora Soler" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Pastora Soler</h2>
						</div>
					</a>
				</article>

				<!-- Feria Mestizas (29 agosto) -->
				<article class="eventos-festival-card">
					<a href="https://www.enterticket.es/eventos/mestiza-morochos-linares-791400" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/conciertos/20260829Feria mestizas.webp" alt="Feria Mestizas" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Mestizas</h2>
						</div>
					</a>
				</article>

				<!-- Feria Taburete (30 agosto) -->
				<article class="eventos-festival-card">
					<a href="https://www.enterticket.es/eventos/taburete-linares-100878" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/conciertos/20260830Feria taburete  taburete.webp" alt="Feria Taburete" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Taburete</h2>
						</div>
					</a>
				</article>

				<!-- Salistre (26 septiembre) -->
				<article class="eventos-festival-card">
					<a href="https://www.enterticket.es/eventos/salistre-ubeda-218127" class="eventos-festival-card__link">
						<div class="eventos-festival-card__image">
							<img src="/eventos/conciertos/20260926salistre.webp" alt="Salistre" width="800" height="533" loading="lazy" decoding="async" />
						</div>
						<div class="eventos-festival-card__body">
							<h2 class="eventos-festival-card__title">Salistre</h2>
						</div>
					</a>
				</article>
			</div>
		</section>

	</div>
</Layout>
