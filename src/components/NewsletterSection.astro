---
import NewsletterForm from './NewsletterForm';
---

<section class="bg-[#050811] border-y border-white/10 py-20 px-6 lg:px-0">
	<div class="max-w-5xl mx-auto grid gap-12 md:grid-cols-2 items-center">
		<div class="space-y-5">
			<p class="text-[10px] tracking-[0.35em] uppercase text-cyan-400">Newsletter</p>
			<h2 class="text-2xl sm:text-3xl font-extrabold tracking-wide leading-snug text-white">
				Sé el primero en enterarte de lo que pasa en CDEM
			</h2>
			<p class="text-sm text-white/60 leading-relaxed">
				Programación de festivales y conciertos, novedades de producción,
				artistas con los que trabajamos y convocatorias exclusivas para nuestra comunidad.
				Sin spam. Solo música.
			</p>
		</div>
		<div>
			<NewsletterForm client:load />
		</div>
	</div>
</section>
