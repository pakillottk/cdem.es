---
---

<footer
	id="contacto"
	class="bg-black border-t border-white/10 px-6 lg:px-0 py-12"
>
	<div class="max-w-5xl mx-auto grid gap-10 md:grid-cols-[1.5fr,1fr] items-start">
		<div class="space-y-4 text-sm">
			<div class="text-3xl tracking-[0.3em] font-semibold">CDEM</div>
			<div class="space-y-1 text-xs uppercase tracking-[0.25em] text-white/70">
				<p>Contacto</p>
				<p>Aviso legal</p>
				<p>Poltica de cookies</p>
				<p>Poltica de privacidad</p>
			</div>
			<div class="flex gap-4 pt-4 text-xl">
				<a href="#" aria-label="Instagram" class="hover:text-primary transition-colors">?</a>
				<a href="#" aria-label="LinkedIn" class="hover:text-primary transition-colors">?</a>
				<a href="#" aria-label="Facebook" class="hover:text-primary transition-colors">?</a>
			</div>
			<p class="pt-4 text-[10px] text-white/50 uppercase tracking-[0.25em]">
				Todos los derechos reservados  {new Date().getFullYear()} CDEM Creación de Eventos Musicales
			</p>
		</div>

		<div class="space-y-4">
			<h2 class="text-sm font-semibold tracking-[0.25em] uppercase">
				Suscrbete a nuestra newsletter
			</h2>
			<form class="space-y-3">
				<div class="space-y-1">
					<label class="block text-[11px] uppercase tracking-[0.2em] text-white/70">
						Nombre y apellidos
					</label>
					<input
						type="text"
						class="w-full bg-transparent border border-white/30 px-3 py-2 text-sm outline-none focus:border-cyan-400 transition-colors"
					/>
				</div>
				<div class="space-y-1">
					<label class="block text-[11px] uppercase tracking-[0.2em] text-white/70">
						Email
					</label>
					<input
						type="email"
						class="w-full bg-transparent border border-white/30 px-3 py-2 text-sm outline-none focus:border-cyan-400 transition-colors"
					/>
				</div>
				<div class="space-y-1">
					<label class="block text-[11px] uppercase tracking-[0.2em] text-white/70">
						Poltica de privacidad
					</label>
					<select
						class="w-full bg-transparent border border-white/30 px-3 py-2 text-sm outline-none focus:border-cyan-400 transition-colors"
					>
						<option value="" selected disabled class="bg-black">
							Acepto la poltica de privacidad
						</option>
						<option value="yes" class="bg-black">S</option>
					</select>
				</div>
				<button
					type="submit"
					class="mt-3 inline-flex items-center justify-center rounded-full bg-cyan-400 text-black px-8 py-2 text-xs font-semibold tracking-[0.25em] uppercase hover:bg-white transition-colors"
				>
					Enviar
				</button>
			</form>
		</div>
	</div>
</footer>


