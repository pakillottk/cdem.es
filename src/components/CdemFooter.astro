---
import NewsletterForm from "./NewsletterForm";
import cdemLogo from "../assets/cdemLogo.webp";
---


<footer id="contacto" class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a href="/"
        ><img src={cdemLogo.src} alt="CDEM" class="site-footer__logo" /></a
      >
    </div>
    <div class="site-footer__links">
      <a href="/contacto" class="site-footer__link">Contacto</a>
      <a href="/aviso-legal" class="site-footer__link">Aviso legal</a>
      <a href="/politica-de-cookies" class="site-footer__link">Política de cookies</a>
      <a href="/politica-de-privacidad" class="site-footer__link">Política de privacidad</a>
    </div>
    <div class="site-footer__social">
      <a href="https://www.instagram.com/cdem_agendaespectaculos/" aria-label="Instagram" target="_blank" rel="noopener noreferrer" class="site-footer__social-link"
        ><img class="site-footer__social-icon" src="/rrss/rrss-ig.webp" alt="Instagram" loading="lazy" decoding="async" /></a
      >
      <a href="https://www.linkedin.com/company/cdemproducciones/" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer" class="site-footer__social-link"
        ><img class="site-footer__social-icon" src="/rrss/rrss-linke.webp" alt="LinkedIn" loading="lazy" decoding="async" /></a
      >
      <a href="https://www.facebook.com/cdemconciertos" aria-label="Facebook" target="_blank" rel="noopener noreferrer" class="site-footer__social-link"
        ><img class="site-footer__social-icon" src="/rrss/rrss-facebook.webp" alt="Facebook" loading="lazy" decoding="async" /></a
      >
    </div>

    <div class="site-footer__newsletter">
      <h2 class="site-footer__newsletter-title">
        Suscríbete a nuestra newsletter
      </h2>
      <div class="site-footer__form">
        <NewsletterForm client:idle />
      </div>
    </div>
  </div>
  
  <div class="site-footer__bottom">
	<p class="site-footer__bottom-text">
	  Todos los derechos reservados {new Date().getFullYear()} CDEM Creación y Diseño
	  de Eventos Musicales
	</p>
  </div>
</footer>
