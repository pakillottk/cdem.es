# Variables opcionales para desarrollo local.
# Copia a `.env` o `.dev.vars` según necesites.

# ── Contacto / newsletter (opcional en local) ────────────────────────────────
# RESEND_API_KEY=
# CONTACT_EMAIL_TO=
# FROM_EMAIL=

# ── Turnstile (opcional en local; e2e:serve usa claves de test) ─────────────
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# TURNSTILE_TEST_MODE=true
# PREVIEW_SECRET=
# MINOR_AUTH_SECRET=   # firma de enlaces de autorización de menores (si falta, usa PREVIEW_SECRET)

# ── Keystatic CMS ────────────────────────────────────────────────────────────
# En local NO definas KEYSTATIC_STORAGE → usa filesystem (storage local).
# En Cloudflare Workers (staging/producción) usa KEYSTATIC_STORAGE=github.

# KEYSTATIC_STORAGE=github
# KEYSTATIC_GITHUB_CLIENT_ID=          # OAuth App de GitHub
# KEYSTATIC_GITHUB_CLIENT_SECRET=      # Secret de la OAuth App
# KEYSTATIC_SECRET=                    # Secreto aleatorio para sesiones OAuth

# Crear OAuth App en GitHub:
#   Homepage URL: https://cdem.es
#   Callback URL: https://cdem.es/api/keystatic/github/oauth/callback
#   Añade también callbacks de preview, p. ej.:
#   https://develop-cdem-es.cdemtic.workers.dev/api/keystatic/github/oauth/callback

# Seguridad adicional recomendada en Cloudflare Zero Trust:
#   Proteger /keystatic*, /admin*, /api/keystatic* con Cloudflare Access.
