{
	"main": "@astrojs/cloudflare/entrypoints/server",
	"name": "cdem-es",
  "compatibility_date": "2025-12-10",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
    "enabled": true
  },
  "vars": {
    // Vacío en producción. deploy:preview lo sobreescribe con el secret real via --var.
    "PREVIEW_SECRET": ""
  }
}